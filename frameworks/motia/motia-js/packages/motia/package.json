{
  "name": "motia",
  "version": "1.0.4-rc.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "[DEPRECATED — moved to iii.dev] Motia is a library for building AI-powered applications.",
  "repository": {
    "type": "git",
    "url": "https://github.com/iii-hq/iii.git",
    "directory": "frameworks/motia/motia-js/packages/motia"
  },
  "homepage": "https://www.motia.dev",
  "keywords": [
    "ai",
    "agentic"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "test": "jest --selectProjects unit",
    "test:unit": "jest --selectProjects unit",
    "test:coverage": "jest --selectProjects unit --coverage --coverageReporters=text",
    "test:integration": "jest --selectProjects integration",
    "test:ci": "jest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./build": {
      "types": "./dist/build.d.mts",
      "require": "./dist/build.cjs",
      "import": "./dist/build.mjs"
    }
  },
  "bin": {
    "motia": "./dist/new/cli.mjs",
    "motia-iii": "./dist/new/cli.mjs"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0",
    "dotenv": "^16.5.0",
    "esbuild": "^0.27.0",
    "glob": "^13.0.0",
    "iii-sdk": "workspace:*",
    "json-schema-to-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "commander": "^14.0.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsdown": "^0.17.0"
  }
}
