<style>
  .fb {
    display: inline-block;
    color: var(--ink);
  }
  .fb :global(svg) {
    width: 28px;
    height: 28px;
    display: block;
    margin-bottom: 12px;
  }
  .fb :global(.bar),
  .fb :global(.accent) {
    fill: var(--ink);
  }
</style>
