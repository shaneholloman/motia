{
  "name": "iii-monorepo",
  "private": true,
  "license": "SEE README.md and CONTRIBUTING.md",
  "scripts": {
    "build": "turbo run build",
    "build:node": "turbo run build --filter=iii-sdk --filter=console-frontend",
    "build:rust": "cargo build --release",
    "build:engine": "cargo build --release -p iii",
    "build:console": "turbo run build:binary --filter=console-frontend && cargo build --release -p iii-console",
    "test": "turbo run test",
    "test:node": "turbo run test --filter=iii-sdk",
    "test:rust": "cargo test --workspace --all-features",
    "test:engine": "cargo test -p iii --all-features",
    "test:sdk-node": "turbo run test --filter=iii-sdk",
    "test:sdk-rust": "cargo test -p iii-sdk --all-features",
    "lint": "turbo run lint",
    "lint:node": "biome check .",
    "lint:rust": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "fmt": "biome format --write . && cargo fmt --all",
    "fmt:check": "biome check . && cargo fmt --all -- --check",
    "type-check": "turbo run type-check",
    "generate:api-docs": "bash scripts/generate-api-docs.sh",
    "dev:docs": "cd docs && npx mint dev",
    "dev:website": "turbo run dev --filter=iii-website",
    "dev:console": "turbo run dev --filter=console-frontend"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20"
  }
}
